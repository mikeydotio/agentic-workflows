{
  "description": "Freshen hooks — automatic /clear and re-invocation via tmux send-keys",
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/on-stop.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/on-clear.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "startup,resume,compact",
        "hooks": [
          {
            "type": "command",
            "command": "rm -f .freshen/*.signal .freshen/.clear-pending 2>/dev/null; exit 0",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
